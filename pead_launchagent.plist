<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.yann.spxquant.pead</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/env</string>
        <string>bash</string>
        <string>-lc</string>
        <string>cd /Users/yann/spx-quant-engine &amp;&amp; /Library/Frameworks/Python.framework/Versions/3.12/bin/python3 pead_engine.py scan &gt;&gt; /Users/yann/spx-quant-engine/data/pead/signals/cron.log 2&gt;&amp;1</string>
    </array>

    <key>StartCalendarInterval</key>
    <array>
        <!-- 22:05 Paris = 16:05 NY (5 min après close) -->
        <dict>
            <key>Hour</key>
            <integer>22</integer>
            <key>Minute</key>
            <integer>5</integer>
        </dict>
        <!-- 15:25 Paris = 9:25 NY (5 min avant open, pour earnings BMO) -->
        <dict>
            <key>Hour</key>
            <integer>15</integer>
            <key>Minute</key>
            <integer>25</integer>
        </dict>
    </array>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/yann/spx-quant-engine/data/pead/signals/launchd.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/yann/spx-quant-engine/data/pead/signals/launchd.err.log</string>
</dict>
</plist>
